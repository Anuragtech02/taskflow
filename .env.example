# ===========================================
# TaskFlow Frontend Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values.
# Note: DB, S3, email, and AI keys are only needed by taskflow-server.

# NextAuth.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-change-in-production

# OAuth Providers (optional — leave empty to disable)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Fastify API Server
NEXT_PUBLIC_API_URL=http://localhost:3001

# Internal service-to-service auth (must match taskflow-server's INTERNAL_API_SECRET)
INTERNAL_API_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MAIN_DOMAIN=taskflow.dev
NODE_ENV=development

# Traefik (production)
DOMAIN=localhost
ACME_EMAIL=
TRAEFIK_LOG_LEVEL=INFO
